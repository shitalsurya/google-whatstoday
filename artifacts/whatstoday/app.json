{
  "expo": {
    "name": "WhatsToday",
    "slug": "whatstoday",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "whatstoday",
    "userInterfaceStyle": "automatic",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#e05c1a"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "package": "com.shitalsurya.LifeLens",
      "versionCode": 21
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#e05c1a"
        }
      ],
      "./plugins/withWhatsTodayWidget"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "extra": {
      "router": {
      },
      "eas": {
        "projectId": "3d876205-f680-4846-86a2-4f83427bb463"
      }
    }
  }
}
